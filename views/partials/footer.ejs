  </main>

  <!-- Asset Detail Modal -->
  <div id="assetModal" class="modal" role="dialog" aria-modal="true" aria-labelledby="modalTitle" hidden>
    <div class="modal-backdrop" id="modalBackdrop"></div>
    <div class="modal-box">
      <button class="modal-close" id="modalClose" aria-label="ปิด">&times;</button>
      <div class="modal-media" id="modalMedia"></div>
      <div class="modal-info">
        <h2 class="modal-title" id="modalTitle"></h2>
        <dl class="modal-meta" id="modalMeta"></dl>
        <div class="modal-actions" id="modalActions"></div>
      </div>
    </div>
  </div>

  <!-- Multi-select Float Bar -->
  <div id="selectBar" class="select-bar" hidden>
    <span class="select-bar-count" id="selectCount">0 รายการ</span>
    <div class="select-bar-actions">
      <button type="button" class="btn btn--ghost select-bar-btn" id="selectDownloadBtn">
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
          <path d="M8 2v9M5 8l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M2 13h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        ดาวน์โหลด
      </button>
      <button type="button" class="btn btn--ghost select-bar-btn" id="selectCopyBtn">
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
          <path d="M6 3a1 1 0 00-1 1v8a1 1 0 001 1h7a1 1 0 001-1V7l-3-4H6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          <path d="M10 3v4h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M3 5H2a1 1 0 00-1 1v8a1 1 0 001 1h7a1 1 0 001-1v-1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Copy ลิงก์
      </button>
      <button type="button" class="btn btn--primary select-bar-btn" id="selectGdocBtn">
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
          <rect x="2" y="1" width="12" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
          <path d="M5 5h6M5 8h6M5 11h3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Google Doc
      </button>
      <button type="button" class="btn btn--ghost select-bar-btn" id="selectCancelBtn">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
          <path d="M2 2l8 8M10 2L2 10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
        ยกเลิก
      </button>
    </div>
  </div>

  <!-- Google Doc Side Panel -->
  <div class="cl-panel" id="gdocPanel" aria-label="Google Doc">
    <div class="cl-panel-header">
      <span class="cl-panel-title">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="none" style="vertical-align:-2px;margin-right:6px">
          <rect x="2" y="1" width="12" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
          <path d="M5 5h6M5 8h6M5 11h3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Google Doc
      </span>
      <button class="cl-panel-close" id="gdocPanelClose" aria-label="ปิด">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <path d="M4 4l10 10M14 4L4 14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
    <div class="cl-panel-body" id="gdocPanelBody">
      <div class="cl-panel-loading"><div class="spinner"></div></div>
    </div>
  </div>
  <div class="cl-backdrop" id="gdocBackdrop"></div>

  <footer class="site-footer">
    <p>Mimir Media Search &mdash; Internal Use Only</p>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
