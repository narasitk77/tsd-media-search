<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <script>
    (function () {
      try {
        if (localStorage.getItem('mimir-theme') === 'dark') {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      } catch (e) {}
    })();
  </script>
</head>
<body>

  <!-- ── Left Sidebar ─────────────────────────────────────── -->
  <div class="side-nav" id="sideNav">
    <div class="side-nav-header">
      <a href="/" class="side-logo">
        <img src="/images/the-standard-logo.png" alt="The Standard" />
      </a>
    </div>
    <nav class="side-links">
      <a href="/" class="side-link <%= (typeof activeTab === 'undefined' || activeTab === 'search') ? 'active' : '' %>">
        <svg width="17" height="17" viewBox="0 0 16 16" fill="none">
          <circle cx="6.5" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M10 10l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span>ค้นหาสื่อ</span>
      </a>

      <a href="/browse" class="side-link <%= (typeof activeTab !== 'undefined' && activeTab === 'browse') ? 'active' : '' %>">
        <svg width="17" height="17" viewBox="0 0 16 16" fill="none">
          <path d="M1.5 4.5a1 1 0 011-1h3l1.5 1.5H13a1 1 0 011 1v6a1 1 0 01-1 1H2.5a1 1 0 01-1-1V4.5z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
        </svg>
        <span>โฟลเดอร์</span>
      </a>

      <button class="side-link" id="clPanelBtn">
        <svg width="17" height="17" viewBox="0 0 16 16" fill="none">
          <rect x="2" y="1" width="12" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
          <path d="M5 5h6M5 8h6M5 11h3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span>Change Logs</span>
      </button>

      <button class="side-link" id="helpPanelBtn">
        <svg width="17" height="17" viewBox="0 0 16 16" fill="none">
          <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
          <path d="M6 6c0-1.105.895-2 2-2s2 .895 2 2c0 1.333-2 2-2 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="8" cy="12" r="0.75" fill="currentColor"/>
        </svg>
        <span>คู่มือ</span>
      </button>

      <% var adminEmails = (process.env.ADMIN_EMAILS || '').split(',').map(function(e){return e.trim()}); %>
      <% if (typeof user !== 'undefined' && user && adminEmails.includes(user.email)) { %>
        <a href="/admin" class="side-link <%= (typeof activeTab !== 'undefined' && activeTab === 'admin') ? 'active' : '' %>">
          <svg width="17" height="17" viewBox="0 0 16 16" fill="none">
            <rect x="1" y="1" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/>
            <rect x="9" y="1" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/>
            <rect x="1" y="9" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/>
            <rect x="9" y="9" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          <span>Dashboard</span>
        </a>
      <% } %>
    </nav>

    <div class="side-nav-footer">
      <% if (typeof user !== 'undefined' && user) { %>
        <div class="side-user">
          <% if (user.photo) { %>
            <img src="<%= user.photo %>" alt="<%= user.name %>" referrerpolicy="no-referrer" class="side-user-photo" />
          <% } %>
          <div class="side-user-info">
            <div class="side-user-name"><%= user.name || user.email %></div>
            <div class="side-user-email"><%= user.email %></div>
          </div>
        </div>
        <a href="/logout" class="side-logout">
          <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
            <path d="M6 2H3a1 1 0 00-1 1v10a1 1 0 001 1h3M10 11l4-4-4-4M14 8H6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          ออกจากระบบ
        </a>
      <% } %>
    </div>
  </div>

  <!-- ── Backdrop ──────────────────────────────────────────── -->
  <div class="nav-backdrop" id="navBackdrop"></div>

  <!-- ── Changelog right panel ────────────────────────────── -->
  <div class="cl-panel" id="clPanel">
    <div class="cl-panel-header">
      <span class="cl-panel-title">Change Logs</span>
      <button class="cl-panel-close" id="clPanelClose" aria-label="ปิด">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <path d="M4 4l10 10M14 4L4 14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
    <div class="cl-panel-body" id="clPanelBody">
      <div class="cl-panel-loading">
        <div class="spinner"></div>
      </div>
    </div>
  </div>
  <div class="cl-backdrop" id="clBackdrop"></div>

  <!-- ── Top Header ────────────────────────────────────────── -->
  <header class="site-header">
    <div class="header-inner">
      <!-- Hamburger -->
      <button class="hamburger" id="menuToggle" aria-label="เมนู">
        <span></span><span></span><span></span>
      </button>

      <!-- Logo -->
      <a href="/" class="logo">
        <img src="/images/the-standard-logo.png" alt="The Standard" class="logo-img" />
        <span class="logo-text">Media Search <span class="logo-demo">v2.9.0</span></span>
      </a>

      <!-- Centered search bar -->
      <div class="header-search">
        <form class="header-search-form" action="/search" method="GET" role="search">
          <input
            type="text"
            name="q"
            class="header-search-input"
            placeholder="ค้นหาสื่อ..."
            value="<%= typeof query !== 'undefined' ? query : '' %>"
            autocomplete="off"
            aria-label="ค้นหา"
          />
          <button type="submit" class="header-search-btn" aria-label="ค้นหา">
            <svg width="17" height="17" viewBox="0 0 20 20" fill="none">
              <circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="2"/>
              <path d="M13 13l4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </button>
        </form>
      </div>

      <div class="header-right">
        <!-- Theme toggle -->
        <button class="theme-toggle" id="themeToggle" aria-label="เปลี่ยนธีม">
          <svg class="theme-icon theme-icon--dark" width="17" height="17" viewBox="0 0 24 24" fill="none">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <svg class="theme-icon theme-icon--light" width="17" height="17" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="2"/>
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
        <!-- User avatar -->
        <% if (typeof user !== 'undefined' && user && user.photo) { %>
          <img src="<%= user.photo %>" alt="<%= user.name %>" referrerpolicy="no-referrer" class="header-avatar" />
        <% } %>
      </div>
    </div>
  </header>
  <main class="main-content">
