# ── App ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
SESSION_SECRET=change-this-to-a-long-random-string

# ── Mimir DAM API ─────────────────────────────────────────────
MIMIR_BASE_URL=https://apac.mjoll.no/api/v1
MIMIR_USERNAME=
MIMIR_PASSWORD=
MIMIR_COGNITO_USER_POOL_ID=
MIMIR_COGNITO_CLIENT_ID=
MIMIR_COGNITO_OIDC_TOKEN_ENDPOINT=

# ── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ── Admin ─────────────────────────────────────────────────────
ADMIN_EMAILS=admin@thestandard.co

# ── Metadata Tool (internal) ─────────────────────────────────
# Docker: ใช้ค่า default ได้เลย (service name จาก docker-compose.yml)
# Local dev: เปลี่ยนเป็น http://localhost:8000
METADATA_TOOL_URL=http://metadata-tool:8000

# ── Vector DB (Qdrant) ────────────────────────────────────────
# Docker: ใช้ค่า default ได้เลย (service ชื่อ qdrant ใน docker-compose.yml)
# Local dev: เปลี่ยนเป็น http://localhost:6333
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=mimir_assets
